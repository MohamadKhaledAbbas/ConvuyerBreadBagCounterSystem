# Rsync filter rules for ConveyorBreadBagCounterSystem
# Usage: run from the project root and sync the directory contents with a trailing slash.
#        Do not use a shell wildcard like `*` because it skips dotfiles and defeats rsync's directory semantics.
# Example: rsync -avz --progress --filter="merge rsync.rules" ./ rdkboard:/home/sunrise/ConvuyerBreadCounting/

# =============================================================================
# EXCLUDE: Development and temporary files (makes sync faster)
# =============================================================================
- .git/
- .idea/
- .vscode/
- .ipynb_checkpoints/
- .venv/
- venv/
- __pycache__/
- *.pyc
- *.pyo
- *.egg-info/
- .pytest_cache/
- .coverage
- htmlcov/

# Exclude documentation and development files
- docs/
- README.md
- Screenshot*.png
- *.iml
- xml_code_inspect/

# Exclude test files (comment out if you want to sync tests)
- test_*.py
- DetectClassify.ipynb

# Exclude output and temporary data
- output/
- data/logs/
- data/spool/
- data/roi_candidates/
- data/unknown/
- data/dataset/

# =============================================================================
# INCLUDE: Essential application files
# =============================================================================
+ src/
+ src/***

+ helper_scripts/
+ helper_scripts/***

# Main application files
+ main.py
+ container_main.py
+ run_endpoint.py
+ rtsp_h264_recorder.py
+ analyze_track_events.py
+ check_gpu.py

# Supervisor program configs (deployed separately to /etc/supervisor/conf.d/)
+ supervisor/
+ supervisor/***

# Configuration and requirements
+ .gitignore
+ requirements.txt
+ requirements.rdk.txt
+ requirements.windows.txt
+ cyclonedds.xml
+ check_ros2_topics.py
+ test_message_types.py
+ deploy_and_restart.sh
+ ROS2_FRAMESERVER_FIX.md

# =============================================================================
# INCLUDE: Critical data folders (model and classes)
# =============================================================================
+ data/
+ data/classes/
+ data/classes/***
+ data/model/
+ data/model/***
- data/model_converter/Calibration_Detect
- data/model_converter/calibration_images
- data/model_converter/Classify_Calibration
+ data/model_converter/***

+ data/model/wechat_qrcode/
+ data/model/wechat_qrcode/***

# + data/db/
# + data/db/***

# =============================================================================
# EXCLUDE: Everything else in data/ (logs, temp files, etc.)
# =============================================================================
- data/***

# =============================================================================
# FINAL: Exclude everything else not explicitly included
# =============================================================================
- *


